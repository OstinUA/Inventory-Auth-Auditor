{
  "manifest_version": 3,
  "name": "Inventory Auth Auditor",
  "version": "1.4.0",
  "description": "Bulk validator and auditor for ads.txt and app-ads.txt lines. Detect mismatches and export reports.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Line Valid-checker",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}